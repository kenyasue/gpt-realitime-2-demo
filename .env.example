# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Used server-side by:
#   - app/api/session/route.ts  (mints ephemeral keys for the browser WebRTC tab)
#   - bridge/server.ts          (opens a server WebSocket for the Twilio tab)
OPENAI_API_KEY=sk-...

# Realtime model id
OPENAI_REALTIME_MODEL=gpt-realtime-2

# ─── Twilio bridge ───────────────────────────────────────────────────────────
# Required for the Twilio tab. See doc/TWILIO_SETUP.md for setup steps.

# Twilio API credentials (Account SID + Auth Token from console.twilio.com)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# A Twilio phone number you own that supports voice (E.164 format, e.g. +14155550123)
TWILIO_FROM_NUMBER=+14155550123

# Local bridge HTTP/WebSocket port
BRIDGE_PORT=5050

# URL the browser (Twilio tab) uses to reach the bridge. Must match BRIDGE_PORT.
# If you change BRIDGE_PORT, update this and restart `npm run dev` so Next.js
# re-inlines the value (NEXT_PUBLIC_* vars are baked in at startup).
NEXT_PUBLIC_BRIDGE_URL=http://localhost:5050

# Publicly reachable URL of the bridge (e.g. an ngrok https URL).
# Twilio will fetch TwiML from $PUBLIC_BRIDGE_URL/twiml and open a Media
# Stream WebSocket to wss://<host>/media-stream. Must be reachable from
# the public internet — localhost will not work.
PUBLIC_BRIDGE_URL=https://your-tunnel.ngrok-free.app

# Origin allowed to call the bridge from the browser (Next.js dev origin)
BRIDGE_CORS_ORIGIN=http://localhost:3000
