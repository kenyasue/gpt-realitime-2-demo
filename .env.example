# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# OpenAI API key — used server-side only by app/api/session/route.ts
# to mint short-lived ephemeral tokens for the browser WebRTC handshake.
OPENAI_API_KEY=sk-...

# Realtime model id
OPENAI_REALTIME_MODEL=gpt-realtime-2
