{
  "name": "gpt-realitime-2-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:bridge": "tsx watch bridge/server.ts",
    "dev:all": "concurrently -k -n web,bridge -c blue,magenta \"npm:dev\" \"npm:dev:bridge\"",
    "build": "next build",
    "start": "next start",
    "start:bridge": "tsx bridge/server.ts",
    "start:all": "concurrently -k -n web,bridge -c blue,magenta \"npm:start\" \"npm:start:bridge\"",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.1",
    "@fastify/websocket": "^11.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "next": "^15.1.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twilio": "^5.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
